# Copiar a .env (NUNCA commitear .env, ya esta cubierto por el .gitignore raiz).
# Cada microservicio del backend es un API Gateway distinto -> 4 URLs distintas.
# Sacalas de la salida de "serverless deploy" de cada servicio (o "serverless info --stage dev").
VITE_AUTH_API=https://xxxxx.execute-api.us-east-1.amazonaws.com/dev
VITE_CATALOGO_API=https://xxxxx.execute-api.us-east-1.amazonaws.com/dev
VITE_PEDIDOS_API=https://xxxxx.execute-api.us-east-1.amazonaws.com/dev
VITE_WORKFLOW_API=https://xxxxx.execute-api.us-east-1.amazonaws.com/dev
VITE_TENANT_ID=popeyes
